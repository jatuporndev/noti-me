# Copy to .env.local for local dev (vercel dev reads .env.local automatically).
# Set these as Environment Variables in the Vercel dashboard for production.

# ── Firebase Admin ──────────────────────────────────────────────────────────
# Paste the full contents of your Firebase service-account JSON as a single
# line (minified). Generate it in Firebase console → Project settings →
# Service accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Dispatch secret ──────────────────────────────────────────────────────────
# Any long random string. Set the same value in your Google Apps Script
# property store (PropertiesService) and send it as header x-dispatch-secret.
DISPATCH_SECRET=replace-with-a-long-random-secret
